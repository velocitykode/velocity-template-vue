# App
APP_NAME=Velocity
APP_ENV=development
APP_URL=http://localhost:4000
APP_PORT=4000

# Logging
LOG_DRIVER=console
LOG_LEVEL=info

# Encryption & signing - the installer populates these with random
# 32-byte base64 values at install time. APP_KEY is also the crypto
# fallback; set CRYPTO_KEY explicitly only if you want a dedicated
# crypto key separate from APP_KEY.
APP_KEY=
QUEUE_SIGNING_KEY=
AUTH_JWT_SECRET=
CRYPTO_CIPHER=AES-256-CBC

# Enable to revoke blacklisted JWT IDs.
AUTH_JWT_BLACKLIST_ENABLED=false

# Database
DB_CONNECTION=sqlite
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=database.sqlite
DB_USERNAME=
DB_PASSWORD=
# DB_CHARSET=utf8mb4
# DB_COLLATION=utf8mb4_unicode_ci
# DB_PREFIX=
# DB_SCHEMA=public
# DB_SSL_MODE=disable
# DB_TIMEZONE=UTC
# DB_LOG_QUERIES=false
# DB_SLOW_QUERY_THRESHOLD=100
# DB_MAX_OPEN_CONNS=25
# DB_MAX_IDLE_CONNS=5
# DB_CONN_MAX_LIFETIME=300

# Cache
CACHE_DRIVER=memory
# CACHE_PREFIX=velocity_
# CACHE_PATH=storage/cache

# Session
SESSION_DRIVER=cookie
SESSION_NAME=velocity_session
SESSION_LIFETIME=120
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# CSRF
# CSRF_TOKEN_LIFETIME=24h
# CSRF_HEADER=X-CSRF-Token
# CSRF_FORM_FIELD=_token
# CSRF_COOKIE_NAME=csrf_token
# CSRF_SECURE=true
# CSRF_HTTP_ONLY=true
# CSRF_SAME_SITE=lax
# CSRF_SINGLE_USE=false

# Authentication
AUTH_GUARD=web
AUTH_MODEL=User

# Hashing
# HASH_BCRYPT_COST=12

# Queue
# QUEUE_DRIVER=sync
# QUEUE_REDIS_HOST=127.0.0.1
# QUEUE_REDIS_PORT=6379
# QUEUE_REDIS_PASSWORD=
# QUEUE_REDIS_DB=0

# Redis
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DATABASE=0

# Mail
# MAIL_DRIVER=smtp
# MAIL_HOST=smtp.mailtrap.io
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=hello@example.com
# MAIL_FROM_NAME="${APP_NAME}"

# Mailgun
# MAILGUN_DOMAIN=
# MAILGUN_SECRET=
# MAILGUN_ENDPOINT=api.mailgun.net

# Postmark
# POSTMARK_TOKEN=
# POSTMARK_MESSAGE_STREAM=outbound

# AWS / S3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
# AWS_URL=
# AWS_VISIBILITY=private

# Filesystem
FILESYSTEM_DISK=local
# FILESYSTEM_LOCAL_ROOT=storage/app
# FILESYSTEM_LOCAL_URL=/storage
# FILESYSTEM_LOCAL_VISIBILITY=private
# FILESYSTEM_PUBLIC_ROOT=storage/app/public
# FILESYSTEM_PUBLIC_URL=/storage

# JWT tuning (secret + blacklist flag live at the top of this file).
# AUTH_JWT_TTL=60
# AUTH_JWT_REFRESH_TTL=20160

# Inertia SSR
# Point INERTIA_SSR_URL at Vite in development (http://localhost:5173/__inertia_ssr)
# or at a running Node SSR bundle in production (http://127.0.0.1:13714/render).
# INERTIA_SSR_ENABLED=false
# INERTIA_SSR_URL=http://127.0.0.1:13714/render
# INERTIA_SSR_TIMEOUT=3s
# INERTIA_SSR_EXCEPT=/admin,/internal
